generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id         String   @id @default(cuid())
  name       String
  price      String
  capacity   String
  optimalFor String
  location   String?  // NAYA: Normal text location
  image      String?  // <--- Ye line hona bahut zaroori hai!
  createdAt  DateTime @default(now())
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  phone     String
  address   String
  status    String   @default("NEW") // NEW, CONTACTED, CONVERTED, CLOSED
  createdAt DateTime @default(now())
}

model ServiceRequest {
  id          String   @id @default(uuid())
  name        String
  phone       String
  address     String
  issue       String
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, RESOLVED
  createdAt   DateTime @default(now())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  author     String
  text       String
  rating     Int
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model User {
  id                 String              @id @default(uuid())
  phone              String              @unique
  name               String?
  createdAt          DateTime            @default(now())
  serviceRequests    ServiceRequest[]
  installationStatus InstallationStatus?
}

model InstallationStatus {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("Processing") // e.g. Processing, Site Inspection, Installation Scheduled, Installed
  progress  Int      @default(10) // Percentage: 10, 25, 75, 100
  updatedAt DateTime @updatedAt
}
model GalleryItem {
  id        String   @id @default(cuid())
  title     String   // Project ka naam (e.g., "Pali Commercial")
  type      String   // Sirf do hi option rakhna: "Photos" ya "Videos"
  category  String   // "Project Photo", "Case Study", etc.
  mediaUrl  String   // Image ya Video ka link (URL)
  createdAt DateTime @default(now())
}
// Ye tera Pricing Manager ka database hai
model ServicePlan {
  id          String   @id @default(cuid())
  name        String   // "Family Pack"
  kw          String   // "3 kW"
  price       String   // "2,10,000"
  description String   // "Handles 1.5 Ton AC..."
  updatedAt   DateTime @updatedAt
}
model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  name      String
  createdAt DateTime @default(now())
}
// Naya Portfolio Model
model Portfolio {
  id          String   @id @default(cuid())
  type        String   // "Photos" ya "Videos"
  title       String   // Jaise: "Commercial Array - Pali"
  category    String   // Jaise: "Project Photo"
  coverImage  String   // Main samne dikhne wali photo
  images      String   // Slider ke liye extra photos (Comma-separated)
  videoUrl    String?  // Agar video hai toh uska link
  createdAt   DateTime @default(now())
}